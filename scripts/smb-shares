#!/bin/bash
# SMB WebAdmin – sharebeheer
# Gebruik:
#   smb-shares create <naam> <pad> <groep>
#   smb-shares delete <naam>
#   smb-shares list
set -euo pipefail

CMD="${1:-}"
SAFE_NAME='^[a-zA-Z0-9._-]{1,32}$'
SAFE_PATH='^/[a-zA-Z0-9._/-]{1,240}$'
SMB_CONF="/etc/samba/smb.conf"

validate_name() {
  if ! [[ "${1:-}" =~ $SAFE_NAME ]]; then
    echo "Ongeldige naam: ${1:-}" >&2
    exit 1
  fi
}

validate_path() {
  if ! [[ "${1:-}" =~ $SAFE_PATH ]] || [[ "${1:-}" == *".."* ]]; then
    echo "Ongeldig pad: ${1:-}" >&2
    exit 1
  fi
}

case "$CMD" in
  create)
    validate_name "${2:-}"
    validate_path "${3:-}"
    validate_name "${4:-}"
    SHARE_NAME="$2"
    SHARE_PATH="$3"
    GROUP_NAME="$4"

    if [[ "$GROUP_NAME" != "none" ]]; then
      getent group "$GROUP_NAME" >/dev/null
    fi

    mkdir -p "$SHARE_PATH"
    if [[ "$GROUP_NAME" != "none" ]]; then
      chown root:"$GROUP_NAME" "$SHARE_PATH"
      chmod 2770 "$SHARE_PATH"
    else
      chmod 0755 "$SHARE_PATH"
    fi

    # Check if share section already exists in smb.conf
    if grep -q "^\[$SHARE_NAME\]" "$SMB_CONF" 2>/dev/null; then
      echo "Share bestaat al in smb.conf: $SHARE_NAME" >&2
      exit 1
    fi

    # Append share section directly to smb.conf
    if [[ "$GROUP_NAME" != "none" ]]; then
      cat >> "$SMB_CONF" <<EOF

[$SHARE_NAME]
   path = $SHARE_PATH
   browseable = yes
   read only = no
   valid users = @$GROUP_NAME
   force group = $GROUP_NAME
   create mask = 0660
   directory mask = 2770
EOF
    else
      cat >> "$SMB_CONF" <<EOF

[$SHARE_NAME]
   path = $SHARE_PATH
   browseable = yes
   read only = no
   create mask = 0644
   directory mask = 0755
EOF
    fi

    testparm -s >/dev/null 2>&1 || true
    systemctl reload smbd 2>/dev/null || systemctl restart smbd 2>/dev/null || true
    ;;

  list)
    python3 - <<'PY'
import json, configparser

SMB_CONF = "/etc/samba/smb.conf"
SKIP = {"global", "printers", "print$"}

result = []
if __import__("os").path.exists(SMB_CONF):
    try:
        with open(SMB_CONF, encoding="utf-8", errors="replace") as f:
            content = f.read()
        cp = configparser.RawConfigParser(strict=False)
        cp.read_string(content)
        for section in cp.sections():
            if section.lower() in SKIP:
                continue
            valid_users = cp.get(section, "valid users", fallback="")
            group = valid_users[1:].strip() if valid_users.startswith("@") else ""
            result.append({
                "name": section,
                "path": cp.get(section, "path", fallback=""),
                "group": group,
                "read_only":       cp.get(section, "read only",       fallback="").strip().lower(),
                "browseable":      cp.get(section, "browseable",      fallback="").strip().lower(),
                "guest_ok":        cp.get(section, "guest ok",        fallback="").strip().lower(),
                "oplocks":         cp.get(section, "oplocks",         fallback="").strip().lower(),
                "level2_oplocks":  cp.get(section, "level2 oplocks",  fallback="").strip().lower(),
                "change_notify":   cp.get(section, "change notify",   fallback="").strip().lower(),
            })
    except (OSError, configparser.Error):
        pass

print(json.dumps(result))
PY
    ;;

  update)
    validate_name "${2:-}"
    SHARE_NAME="$2"
    GROUP_NAME="${3:-none}"
    READ_ONLY="${4:-no}"
    BROWSEABLE="${5:-yes}"
    GUEST_OK="${6:-no}"
    LEVEL2_OPLOCKS="${7:-}"
    CHANGE_NOTIFY="${8:-}"
    OPLOCKS="${9:-}"

    if [[ "$GROUP_NAME" != "none" ]]; then
      validate_name "$GROUP_NAME"
      getent group "$GROUP_NAME" >/dev/null
    fi

    python3 - "$SHARE_NAME" "$GROUP_NAME" "$READ_ONLY" "$BROWSEABLE" "$GUEST_OK" "$LEVEL2_OPLOCKS" "$CHANGE_NOTIFY" "$OPLOCKS" <<'PY'
import sys
from pathlib import Path

name = sys.argv[1]
group = sys.argv[2]
read_only = sys.argv[3]
browseable = sys.argv[4]
guest_ok = sys.argv[5]
level2_oplocks = sys.argv[6]
change_notify = sys.argv[7]
oplocks = sys.argv[8]
conf_path = Path("/etc/samba/smb.conf")
if not conf_path.exists():
    print("smb.conf niet gevonden", file=sys.stderr)
    sys.exit(1)
lines = conf_path.read_text(encoding="utf-8", errors="replace").splitlines(keepends=True)

desired = {
    "read only": read_only,
    "browseable": browseable,
    "guest ok": "yes" if guest_ok == "yes" else None,
    "oplocks": oplocks if oplocks in ("yes", "no") else None,
    "level2 oplocks": level2_oplocks if level2_oplocks in ("yes", "no") else None,
    "change notify": change_notify if change_notify in ("yes", "no") else None,
}
if group not in ("none", ""):
    desired["valid users"] = f"@{group}"
    desired["force group"] = group
    desired["create mask"] = "0660"
    desired["directory mask"] = "2770"
else:
    desired["valid users"] = None
    desired["force group"] = None
    desired["create mask"] = "0644"
    desired["directory mask"] = "0755"

result = []
in_section = False
handled = set()
found = False
pending_blanks = []
for line in lines:
    stripped = line.strip()
    if stripped == f"[{name}]":
        found = True
        in_section = True
        result.append(line)
        continue
    if in_section and stripped.startswith("[") and stripped.endswith("]"):
        for k, v in desired.items():
            if k not in handled and v is not None:
                result.append(f"   {k} = {v}\n")
        result.extend(pending_blanks)
        pending_blanks = []
        in_section = False
        result.append(line)
        continue
    if in_section and not stripped:
        pending_blanks.append(line)
        continue
    if pending_blanks:
        result.extend(pending_blanks)
        pending_blanks = []
    if in_section and "=" in stripped:
        key = stripped.split("=")[0].strip().lower()
        if key in desired:
            handled.add(key)
            if desired[key] is not None:
                result.append(f"   {key} = {desired[key]}\n")
            continue
    result.append(line)

if in_section:
    for k, v in desired.items():
        if k not in handled and v is not None:
            result.append(f"   {k} = {v}\n")
    result.extend(pending_blanks)

if not found:
    print(f"Share niet gevonden: {name}", file=sys.stderr)
    sys.exit(1)

conf_path.write_text("".join(result), encoding="utf-8")
PY
    testparm -s >/dev/null 2>&1 || true
    systemctl reload smbd 2>/dev/null || systemctl restart smbd 2>/dev/null || true
    ;;

  delete)
    validate_name "${2:-}"
    SHARE_NAME="$2"
    # Remove share section from smb.conf
    python3 - "$SHARE_NAME" <<'PY'
import sys
from pathlib import Path

name = sys.argv[1]
conf = Path("/etc/samba/smb.conf")
if not conf.exists():
    print("smb.conf niet gevonden", file=sys.stderr)
    sys.exit(1)
lines = conf.read_text(encoding="utf-8", errors="replace").splitlines(keepends=True)
result = []
skip = False
found = False
for line in lines:
    stripped = line.strip()
    if stripped == f"[{name}]":
        skip = True
        found = True
        continue
    if skip and stripped.startswith("[") and stripped.endswith("]"):
        skip = False
    if not skip:
        result.append(line)
if not found:
    print(f"Share niet gevonden in smb.conf: {name}", file=sys.stderr)
    sys.exit(1)
# Strip trailing blank lines that were part of the removed section
conf.write_text("".join(result).rstrip("\n") + "\n", encoding="utf-8")
PY
    testparm -s >/dev/null 2>&1 || true
    systemctl reload smbd 2>/dev/null || systemctl restart smbd 2>/dev/null || true
    ;;

  *)
    echo "Gebruik: smb-shares {create <naam> <pad> <groep>|update <naam> <groep> <read_only> <browseable> <guest_ok> <level2_oplocks> <change_notify>|delete <naam>|list}" >&2
    exit 1
    ;;
esac
