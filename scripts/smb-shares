#!/bin/bash
# SMB WebAdmin – sharebeheer
# Gebruik:
#   smb-shares create <naam> <pad> <groep>
#   smb-shares set-acl <pad> <groep> <mode>   (mode: read|write|none)
#   smb-shares delete <naam>
#   smb-shares list
set -euo pipefail

CMD="${1:-}"
SAFE_NAME='^[a-zA-Z0-9._-]{1,32}$'
SAFE_PATH='^/[a-zA-Z0-9._/-]{1,240}$'

validate_name() {
  if ! [[ "${1:-}" =~ $SAFE_NAME ]]; then
    echo "Ongeldige naam: ${1:-}" >&2
    exit 1
  fi
}

validate_path() {
  if ! [[ "${1:-}" =~ $SAFE_PATH ]] || [[ "${1:-}" == *".."* ]]; then
    echo "Ongeldig pad: ${1:-}" >&2
    exit 1
  fi
}

case "$CMD" in
  create)
    validate_name "${2:-}"
    validate_path "${3:-}"
    validate_name "${4:-}"
    SHARE_NAME="$2"
    SHARE_PATH="$3"
    GROUP_NAME="$4"

    getent group "$GROUP_NAME" >/dev/null

    mkdir -p "$SHARE_PATH"
    chown root:"$GROUP_NAME" "$SHARE_PATH"
    chmod 2770 "$SHARE_PATH"

    CONF_DIR="/etc/samba/smb-webadmin.d"
    CONF_FILE="$CONF_DIR/$SHARE_NAME.conf"
    mkdir -p "$CONF_DIR"

    cat > "$CONF_FILE" <<EOF
[$SHARE_NAME]
   path = $SHARE_PATH
   browseable = yes
   read only = no
   valid users = @$GROUP_NAME
   force group = $GROUP_NAME
   create mask = 0660
   directory mask = 2770
EOF

    # Remove any existing include line (may have been appended in wrong location)
    sed -i '/^[[:space:]]*include = \/etc\/samba\/smb-webadmin\.d\/\*\.conf/d' /etc/samba/smb.conf
    # Insert include directive into the [global] section so Samba loads it
    if grep -q "^\[global\]" /etc/samba/smb.conf; then
      sed -i "/^\[global\]/a\\    include = /etc/samba/smb-webadmin.d/*.conf" /etc/samba/smb.conf
    else
      printf '\n[global]\n    include = /etc/samba/smb-webadmin.d/*.conf\n' >> /etc/samba/smb.conf
    fi

    testparm -s >/dev/null
    systemctl reload smbd 2>/dev/null || systemctl restart smbd 2>/dev/null || true
    ;;

  set-acl)
    validate_path "${2:-}"
    validate_name "${3:-}"
    SHARE_PATH="$2"
    GROUP_NAME="$3"
    MODE="${4:-}"

    getent group "$GROUP_NAME" >/dev/null
    test -d "$SHARE_PATH"

    case "$MODE" in
      read)
        setfacl -R -m "g:$GROUP_NAME:rx" "$SHARE_PATH"
        setfacl -R -d -m "g:$GROUP_NAME:rx" "$SHARE_PATH"
        ;;
      write)
        setfacl -R -m "g:$GROUP_NAME:rwx" "$SHARE_PATH"
        setfacl -R -d -m "g:$GROUP_NAME:rwx" "$SHARE_PATH"
        ;;
      none)
        setfacl -R -x "g:$GROUP_NAME" "$SHARE_PATH" 2>/dev/null || true
        setfacl -R -d -x "g:$GROUP_NAME" "$SHARE_PATH" 2>/dev/null || true
        ;;
      *)
        echo "Ongeldige mode: $MODE (kies read, write of none)" >&2
        exit 1
        ;;
    esac
    ;;

  list)
    python3 - <<'PY'
import os, re, json, configparser

CONF_DIR = "/etc/samba/smb-webadmin.d"
SMB_CONF = "/etc/samba/smb.conf"
SKIP = {"global", "homes", "printers", "print$"}

def match_val(pattern, content, lower=True):
    m = re.search(pattern, content, re.MULTILINE)
    if not m:
        return ""
    v = m.group(1).strip()
    return v.lower() if lower else v

# Read managed shares (webadmin-created conf files)
managed = {}
if os.path.isdir(CONF_DIR):
    for fname in sorted(os.listdir(CONF_DIR)):
        if not fname.endswith(".conf"):
            continue
        fpath = os.path.join(CONF_DIR, fname)
        try:
            with open(fpath) as f:
                content = f.read()
        except OSError:
            continue
        name = match_val(r"^\[([^\]]+)\]", content, lower=False)
        if name:
            path = match_val(r"^\s*path\s*=\s*(.+)", content, lower=False)
            group_m = re.search(r"^\s*valid users\s*=\s*@(\S+)", content, re.MULTILINE)
            group = group_m.group(1).strip() if group_m else ""
            managed[name] = {
                "name": name,
                "path": path,
                "group": group,
                "read_only":  match_val(r"^\s*read only\s*=\s*(\S+)", content),
                "browseable": match_val(r"^\s*browseable\s*=\s*(\S+)", content),
                "guest_ok":   match_val(r"^\s*guest ok\s*=\s*(\S+)", content),
            }

# Also collect unmanaged shares from main smb.conf
result = list(managed.values())
if os.path.exists(SMB_CONF):
    cp = configparser.RawConfigParser(strict=False)
    cp.read(SMB_CONF)
    for section in cp.sections():
        if section.lower() in SKIP or section in managed:
            continue
        valid_users = cp.get(section, "valid users", fallback="")
        group = valid_users[1:].strip() if valid_users.startswith("@") else ""
        result.append({
            "name": section,
            "path": cp.get(section, "path", fallback=""),
            "group": group,
            "read_only":  cp.get(section, "read only",  fallback="").strip().lower(),
            "browseable": cp.get(section, "browseable", fallback="").strip().lower(),
            "guest_ok":   cp.get(section, "guest ok",   fallback="").strip().lower(),
        })

print(json.dumps(result))
PY
    ;;

  delete)
    validate_name "${2:-}"
    SHARE_NAME="$2"
    CONF_FILE="/etc/samba/smb-webadmin.d/$SHARE_NAME.conf"
    if [ -f "$CONF_FILE" ]; then
      rm -f "$CONF_FILE"
    else
      # Remove unmanaged share section directly from smb.conf
      python3 - "$SHARE_NAME" <<'PY'
import sys
from pathlib import Path

name = sys.argv[1]
conf = Path("/etc/samba/smb.conf")
if not conf.exists():
    print("smb.conf niet gevonden", file=sys.stderr)
    sys.exit(1)
lines = conf.read_text().splitlines(keepends=True)
result = []
skip = False
found = False
for line in lines:
    stripped = line.strip()
    if stripped == f"[{name}]":
        skip = True
        found = True
        continue
    if skip and stripped.startswith("[") and stripped.endswith("]"):
        skip = False
    if not skip:
        result.append(line)
if not found:
    print(f"Share niet gevonden in smb.conf: {name}", file=sys.stderr)
    sys.exit(1)
conf.write_text("".join(result))
PY
    fi
    testparm -s >/dev/null 2>&1 || true
    systemctl reload smbd 2>/dev/null || systemctl restart smbd 2>/dev/null || true
    ;;

  *)
    echo "Gebruik: smb-shares {create <naam> <pad> <groep>|set-acl <pad> <groep> <mode>|delete <naam>|list}" >&2
    exit 1
    ;;
esac
