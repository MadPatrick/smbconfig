#!/bin/bash
set -euo pipefail

SHARE_NAME="$1"
SHARE_PATH="$2"
GROUP_NAME="$3"

if ! [[ "$SHARE_NAME" =~ ^[a-zA-Z0-9._-]{1,32}$ ]]; then
  echo "Invalid share name" >&2
  exit 1
fi

if ! [[ "$SHARE_PATH" =~ ^/[a-zA-Z0-9._/-]{1,240}$ ]] || [[ "$SHARE_PATH" == *".."* ]]; then
  echo "Invalid share path" >&2
  exit 1
fi

if ! [[ "$GROUP_NAME" =~ ^[a-zA-Z0-9._-]{1,32}$ ]]; then
  echo "Invalid group" >&2
  exit 1
fi

getent group "$GROUP_NAME" >/dev/null

mkdir -p "$SHARE_PATH"
chown root:"$GROUP_NAME" "$SHARE_PATH"
chmod 2770 "$SHARE_PATH"

CONF_DIR="/etc/samba/smb-webadmin.d"
CONF_FILE="$CONF_DIR/$SHARE_NAME.conf"
mkdir -p "$CONF_DIR"

cat > "$CONF_FILE" <<EOF
[$SHARE_NAME]
   path = $SHARE_PATH
   browseable = yes
   read only = no
   valid users = @$GROUP_NAME
   force group = $GROUP_NAME
   create mask = 0660
   directory mask = 2770
EOF

if ! grep -q "include = /etc/samba/smb-webadmin.d/*.conf" /etc/samba/smb.conf; then
  printf '\ninclude = /etc/samba/smb-webadmin.d/*.conf\n' >> /etc/samba/smb.conf
fi

testparm -s >/dev/null
systemctl reload smbd 2>/dev/null || systemctl restart smbd 2>/dev/null || true
